{
  "manifest_version": 2,
  "name": "OHM Data Index",
  "version": "0.4.0",
  "description": "Manage Open History Map data descriptors (ohm:* tags) on Zotero items.",
  "homepage_url": "https://openhistorymap.org",
  "author": "Open History Map",
  "applications": {
    "zotero": {
      "id": "ohm-zotero@openhistorymap.org",
      "update_url": "https://github.com/openhistorymap/ohm-zotero/releases/latest/download/update.json",
      "strict_min_version": "6.999",
      "strict_max_version": "99.0.*"
    }
  }
}
